# Environment Variables for CarbonX

# Carbon Intensity Data Source
# Options: "electricity_maps", "static", "watttime"
CARBON_DATA_SOURCE=static

# Electricity Maps API (free tier - optional)
# Get your key at: https://api.electricitymaps.com
ELECTRICITY_MAPS_API_KEY=

# Default region for carbon intensity (ISO 3166-1 alpha-2)
DEFAULT_REGION=US

# Model Configuration
# Available: small, medium, large
DEFAULT_MODEL_SIZE=medium

# HuggingFace model paths (can use local paths or HF model IDs)
MODEL_SMALL=distilgpt2
MODEL_MEDIUM=gpt2
MODEL_LARGE=gpt2-large

# Carbon Budget Settings
DEFAULT_CARBON_BUDGET_GCO2=1000.0
BUDGET_WINDOW_HOURS=24

# Scheduler Weights (α, β, γ for multi-objective optimization)
SCHEDULER_ALPHA_CARBON=0.5
SCHEDULER_BETA_LATENCY=0.3
SCHEDULER_GAMMA_QUALITY=0.2

# Early Exit Configuration
EARLY_EXIT_THRESHOLD=0.85
EARLY_EXIT_ENABLED=true

# Cache Configuration
CACHE_ENABLED=true
CACHE_SIMILARITY_THRESHOLD=0.92

# Redis (optional - for distributed caching)
REDIS_URL=

# Telemetry
TELEMETRY_ENABLED=true
PROMETHEUS_PORT=9090

# API Settings
API_HOST=0.0.0.0
API_PORT=8000

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
